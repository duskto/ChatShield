APP_NAME=ChatShield
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000

DATABASE_URL=sqlite:///./chatshield.db

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT=120
OLLAMA_KEEP_ALIVE=24h
OLLAMA_MODEL_START_TIMEOUT=30

ENABLE_RULE_CHECK=true
ENABLE_API_MODERATION=true

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

INPUT_BLOCK_THRESHOLD=high
OUTPUT_BLOCK_THRESHOLD=high
SAVE_RAW_TEXT=true
CORS_ORIGINS=*
API_REVIEWABLE_RULE_TYPES=prompt_injection,jailbreak,prompt_leakage,policy_evasion,data_exfiltration,tool_abuse,cyber_abuse,malware,illegal,fraud,impersonation,extremism
